{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ReadAllConfigValuesResponse",
  "title": "Read All Configuration Values Response",
  "description": "Response containing all configuration values read from a node, indexed by element path. Failed reads are stored as Invalid values with error messages.",
  "type": "object",
  "properties": {
    "node_id": {
      "type": "string",
      "description": "LCC Node ID that was read from",
      "pattern": "^([0-9A-Fa-f]{2}\\.){5}[0-9A-Fa-f]{2}$"
    },
    "values": {
      "type": "object",
      "description": "Map of element paths to configuration values. Key is element path joined with '/' (e.g., 'Settings/Network/Node Name')",
      "additionalProperties": {
        "$ref": "ReadConfigValueResponse.schema.json"
      },
      "examples": [
        {
          "Settings/Identification/User Name": {
            "value": { "type": "String", "value": "Tower LCC", "size_bytes": 32 },
            "memory_address": 16,
            "address_space": 253,
            "element_path": ["Settings", "Identification", "User Name"],
            "timestamp": "2026-02-19T14:32:00Z"
          },
          "Events/Producers/Output 1": {
            "value": { "type": "EventId", "value": [5, 1, 1, 1, 3, 1, 0, 0] },
            "memory_address": 256,
            "address_space": 253,
            "element_path": ["Events", "Producers", "Output 1"],
            "timestamp": "2026-02-19T14:32:05Z"
          }
        }
      ]
    },
    "total_elements": {
      "type": "integer",
      "description": "Total number of elements attempted to read",
      "minimum": 0
    },
    "successful_reads": {
      "type": "integer",
      "description": "Number of successfully read and parsed values",
      "minimum": 0
    },
    "failed_reads": {
      "type": "integer",
      "description": "Number of failed reads (stored as Invalid values)",
      "minimum": 0
    },
    "duration_ms": {
      "type": "integer",
      "description": "Total duration of the read operation in milliseconds",
      "minimum": 0
    }
  },
  "required": ["node_id", "values", "total_elements", "successful_reads", "failed_reads", "duration_ms"],
  "additionalProperties": false,
  "examples": [
    {
      "node_id": "05.01.01.01.03.01",
      "values": {
        "Settings/Identification/User Name": {
          "value": { "type": "String", "value": "Tower LCC", "size_bytes": 32 },
          "memory_address": 16,
          "address_space": 253,
          "element_path": ["Settings", "Identification", "User Name"],
          "timestamp": "2026-02-19T14:32:00Z"
        }
      },
      "total_elements": 47,
      "successful_reads": 45,
      "failed_reads": 2,
      "duration_ms": 4800
    }
  ]
}
