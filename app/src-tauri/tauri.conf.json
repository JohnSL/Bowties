{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Bowties",
  "version": "0.1.7",
  "identifier": "com.lcc.bowties",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npx svelte-kit sync && npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Bowties::LCC",
        "width": 800,
        "height": 600,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {},
  "bundle": {
    "active": true,
    "targets": ["nsis", "deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "profiles/": "profiles/"
    },
    "windows": {
      "nsis": {
        "installMode": "both"
      }
    }
  }
}
